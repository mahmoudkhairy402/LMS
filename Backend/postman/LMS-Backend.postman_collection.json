{
  "info": {
    "_postman_id": "7c2d7c1f-2d8b-4a8a-9a1a-2f7a8e2d1d01",
    "name": "LMS Backend API",
    "description": "Collection for the LMS backend API.\n\nHow to use:\n1. Import this collection and the matching environment file.\n2. Select the environment before sending requests.\n3. Register, verify email, then login (or Google login).\n4. Access token is stored automatically after login/google/refresh.\n5. Use protected endpoints for profile/courses/enrollments/users.\n\nDynamic variables:\n- base_url\n- access_token\n- verification_token\n- google_id_token\n- google_access_token\n- course_id\n- user_id\n- lesson_id_1\n- lesson_id_2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const token = pm.environment.get('access_token') || pm.collectionVariables.get('access_token');",
          "const skipAuth = ['register', 'login', 'verify-email', 'google', 'health', 'refresh'];",
          "const requestUrl = pm.request.url.toString().toLowerCase();",
          "const shouldAttachAuth = token && !skipAuth.some((part) => requestUrl.includes(part));",
          "if (shouldAttachAuth) {",
          "  pm.request.headers.upsert({ key: 'Authorization', value: `Bearer ${token}` });",
          "}"
        ]
      }
    },
            }
          ]
        },
        {
          "name": "Payments",
          "item": [
            {
              "name": "Create Payment Intent (Protected)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{access_token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"courseId\": \"{{course_id}}\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/payments/create-intent",
                  "host": ["{{base_url}}"],
                  "path": ["api", "payments", "create-intent"]
                },
                "description": "Create a Stripe PaymentIntent for course purchase. Returns clientSecret for frontend payment confirmation."
              }
            },
            {
              "name": "Confirm Payment (Protected)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{access_token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"paymentIntentId\": \"pi_xxxx\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/payments/confirm",
                  "host": ["{{base_url}}"],
                  "path": ["api", "payments", "confirm"]
                },
                "description": "Confirm payment completion and create enrollment. Call this after Stripe confirms the payment."
              }
            },
            {
              "name": "Get Payment Status (Protected)",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{access_token}}" }
                ],
                "url": {
                  "raw": "{{base_url}}/api/payments/get-status/pi_xxxx",
                  "host": ["{{base_url}}"],
                  "path": ["api", "payments", "get-status", "pi_xxxx"]
                },
                "description": "Check the status of a payment. Returns status and enrollment details if successful."
              }
            },
            {
              "name": "Stripe Webhook (Unprotected)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"id\": \"evt_xxxx\",\n  \"type\": \"payment_intent.succeeded\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"pi_xxxx\",\n      \"status\": \"succeeded\"\n    }\n  }\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/webhooks/stripe",
                  "host": ["{{base_url}}"],
                  "path": ["api", "webhooks", "stripe"]
                },
                "description": "Stripe webhook endpoint. Stripe sends payment events here. Must verify Stripe signature before processing."
              }
            }
          ]
        }
        "type": "text/javascript",
        "exec": [
          "const requestName = (pm.info.requestName || '').toLowerCase();",
          "let json = {};",
          "try {",
          "  json = pm.response.json();",
          "} catch (error) {",
          "  json = {};",
          "}",
          "if ((requestName.includes('login') || requestName.includes('refresh') || requestName.includes('google')) && json.accessToken) {",
          "  pm.environment.set('access_token', json.accessToken);",
          "  pm.collectionVariables.set('access_token', json.accessToken);",
          "}",
          "const cookies = pm.cookies.toObject();",
          "if (cookies && cookies.refreshToken) {",
          "  pm.environment.set('refresh_token_cookie', cookies.refreshToken);",
          "  pm.collectionVariables.set('refresh_token_cookie', cookies.refreshToken);",
          "}"
        ]
      }
    }
  ],
